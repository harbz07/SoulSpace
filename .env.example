# =============================================================================
# DISCORD CONFIGURATION
# =============================================================================

# Discord Bot Token
# How to get: https://discord.com/developers/applications
# 1. Create a new application
# 2. Go to "Bot" section
# 3. Click "Reset Token" and copy it
DISCORD_TOKEN=your_discord_bot_token_here

# Discord Channel IDs
# How to get:
# 1. Enable Developer Mode in Discord (User Settings > Advanced > Developer Mode)
# 2. Right-click on any channel and select "Copy ID"
CHANNEL_THE_WELL=111111111111111111      # Main interaction channel
CHANNEL_ENGINE_LOGS=222222222222222222   # System trace logs channel
CHANNEL_THE_SCREAM=333333333333333333    # Error reporting channel
CHANNEL_THE_MIRROR=444444444444444444    # Status updates channel
CHANNEL_THE_COUNSEL=555555555555555555   # Commands and control channel

# =============================================================================
# NOTION CONFIGURATION
# =============================================================================

# Notion Integration Token
# How to get: https://www.notion.so/my-integrations
# 1. Create a new integration
# 2. Copy the "Internal Integration Token"
# 3. Share each database with your integration (click "Share" on database, invite integration)
NOTION_TOKEN=secret_your_notion_integration_token

# Notion Database IDs
# How to get:
# 1. Open the database in Notion (full-page view)
# 2. Copy the URL - it looks like: https://notion.so/workspace/DATABASE_ID?v=VIEW_ID
# 3. The DATABASE_ID is the 32-character hex string between the last slash and the question mark
# Example URL: https://notion.so/myworkspace/a1b2c3d4e5f6...?v=...
#              The ID is: a1b2c3d4e5f6...

# Task Board - tracks all tasks and their status
# Required properties: Task (title), Status (select), Priority (select), 
#                      Assigned To (select), Trigger Source (select), 
#                      Trace Link (url), Blocker Reason (rich_text)
NOTION_TASK_BOARD_ID=your_task_board_database_id

# Trace Log Index - records execution traces for debugging
# Required properties: Trace ID (title), Timestamp (date), Request Summary (rich_text),
#                      Agent Chain (rich_text), Data Sources Used (multi_select),
#                      Discord Link (url), Success (checkbox)
NOTION_TRACE_LOG_ID=your_trace_log_database_id

# Agent Health Monitor - tracks agent status and errors
# Required properties: Agent Name (title), Status (select), Last Execution (date),
#                      Execution Count (number), Error Count (number),
#                      Last Error Message (rich_text), Auth Status (select)
NOTION_AGENT_HEALTH_ID=your_agent_health_database_id

# Knowledge Base - stores verified information
# Required properties: Entry Title (title), Category (select), Consent Level (select),
#                      Source (select), Last Verified (date)
NOTION_KNOWLEDGE_BASE_ID=your_knowledge_base_database_id

# Memory Archive - long-term memory storage
# Required properties: Memory ID (title), Type (select), Consent Status (select),
#                      Created Date (date), Last Accessed (date), Access Count (number),
#                      Retention Policy (select), Content Preview (rich_text)
NOTION_MEMORY_ARCHIVE_ID=your_memory_archive_database_id

# The Glass Journal - broadcast messages database (optional)
JOURNAL_DB_ID=your_journal_database_id

# =============================================================================
# GOOGLE OAUTH CONFIGURATION (Optional - for Gmail/Calendar integration)
# =============================================================================

# Google OAuth Credentials
# How to get: https://console.cloud.google.com/
# 1. Create a new project (or select existing)
# 2. Enable Gmail API and Google Calendar API
# 3. Go to "Credentials" > "Create Credentials" > "OAuth 2.0 Client ID"
# 4. Application type: "Desktop app"
# 5. Copy the Client ID and Client Secret
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret

# =============================================================================
# OPERATIONAL SETTINGS
# =============================================================================

# OAuth Redirect Port
# The local port for OAuth callback handling (default: 9090)
# Make sure this port is not blocked by firewall
OAUTH_REDIRECT_PORT=9090

# Start bot in paused mode (true/false)
# When true, automated triggers are disabled on startup
# Use /resume command to enable them
START_PAUSED=false
